{
  "name": "deadlock-nyc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "wasm": "wasm-pack build wasm --target web --out-dir ../src/wasm/pkg --out-name boon_wasm",
    "sync": "bash scripts/sync-game-data.sh",
    "items": "bun run scripts/build-item-manifest.ts",
    "item-names": "bun run scripts/build-item-names.ts",
    "item-stats": "bun run scripts/build-item-stats.ts",
    "portraits": "bun run scripts/build-hero-portraits.ts",
    "ability-icons": "bun run scripts/build-ability-icons.ts",
    "images": "bun run scripts/build-images.ts",
    "check-modifiers": "bun run scripts/check-modifier-values.ts"
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  }
}
